def detect_template(wb) -> str | None:
    """Detect which template config to use by scanning bs sheet text."""
    try:
        ws = wb['bs']
        text = " ".join(
            str(ws.cell(r, c).value or "")
            for r in range(1, 10) for c in range(1, 5)
        ).upper()
        for key, cfg in TEMPLATE_CONFIGS.items():
            if any(s.upper() in text for s in cfg["match_strings"]):
                return key
    except Exception:
        pass
    return None


def get_config(wb) -> tuple:
    """Return (template_key, config_dict) or (None, None) if unknown."""
    key = detect_template(wb)
    if key:
        return key, TEMPLATE_CONFIGS[key]
    return None, None
