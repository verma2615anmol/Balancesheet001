def fix_lt_bs_pointer(ws_bs: Worksheet, ws_n: Worksheet, log: list):
    """Ensure bs!E11 points to notes LT total row."""
    total_ab = _find_row_by_label(ws_n, ["total (a) + (b)"], start=4, end=28)
    if not total_ab:
        total_ab = _find_row_by_label(ws_n, ["total (a)+(b)"], start=4, end=28)
    if total_ab:
        current = ws_bs.cell(11, 5).value
        expected = f"='notes to bs'!D{total_ab}"
        if current != expected:
            ws_bs.cell(11, 5).value = expected
            log.append(f"\n[LTB_BS] bs!E11 updated: {repr(current)} → {expected}")



# ─────────────────────────────────────────────────────────────────────────────
# Fix: Trade Receivables — D101 points to wrong Details row
# ─────────────────────────────────────────────────────────────────────────────

def fix_trade_receivables(ws_n: Worksheet, ws_det, log: list):
    """
    Fix trade receivable formula to point to actual debtor rows in Details,
    not the advance-to-supplier total.
    """
    log.append("\n[TR] Fixing Trade Receivables")

    # Find the trade receivables section header first
    tr_hdr = _find_row_by_label(ws_n, ["trade receivable"], start=80, end=150)
    if not tr_hdr:
        tr_hdr = _find_row_by_label(ws_n, ["trade rec"], start=80, end=150)
    scan_start = tr_hdr if tr_hdr else 90
    scan_end   = min(scan_start + 30, 150)

    # Find the <6months unsecured debtor row in notes to bs
    for r in range(scan_start, scan_end):
        lbl = _label(ws_n, r)
        if "unsecured considered good" in lbl and "outstanding" not in lbl:
            # Check parent context: should be under <6months section
            parent_lbl = _label(ws_n, r-2)
            if "less than 6" in parent_lbl or "less than" in parent_lbl:
                cell = ws_n.cell(r, 4)
                current = cell.value or ""
                if isinstance(current, str) and "Details" in current:
                    # Find the correct Details trade rec total row
                    # by scanning Details for a SUM of debtor rows
                    if ws_det:
                        for dr in range(60, 90):
                            dv = ws_det.cell(dr, 4).value
                            if isinstance(dv, str) and "SUM" in dv.upper():
                                # Check if this row sums debtor names (not supplier names)
                                # by checking the rows above it
                                for rr in range(max(dr-5, 1), dr):
                                    b2 = (ws_det.cell(rr, 2).value or "").strip().lower()
                                    if any(k in b2 for k in ["online", "credit card",
                                           "industry", "forging", "fabrics", "pvt"]):
                                        cell.value = f"=Details!D{dr}"
                                        log.append(f"  TR: D{r} fixed → =Details!D{dr}")
                                        return
                    # Fallback: scan Details for "ONLINE PAYMENT" and use that row directly
                    if ws_det:
                        for dr in range(60, 90):
                            b2 = (ws_det.cell(dr, 2).value or "").strip().lower()
                            if "online" in b2 or "online payment" in b2:
                                cell.value = f"=Details!D{dr}"
                                log.append(f"  TR: D{r} fixed → =Details!D{dr} (online payment)")
                                return
                log.append(f"  TR: D{r} already correct or no fix needed ({repr(current)})")
                break


def fix_revenue_formula(ws_npl: Worksheet, ws_gp: Worksheet, log: list):
    """Extend revenue SUM to cover all sale rows E11:E16 (some templates only have E11:E14)."""
    log.append("\n[REV] Fixing Revenue formula range")
    if ws_npl is None or ws_gp is None:
        return
    for r in range(1, 20):
        b = ws_npl.cell(r, 2).value
        if b and "sale of goods" in str(b).lower():
            cell = ws_npl.cell(r+1, 4)  # next row = total/sum row
            # Or find the total row
            for rr in range(r, r+5):
                d = ws_npl.cell(rr, 4).value
                if isinstance(d, str) and "GROSS PROFIT" in d and "SUM" in d:
                    # Update to include all sale rows up to E20
                    # Find actual last sale row in GP sheet
                    last_sale_row = 14
                    for gr in range(10, 22):
                        v = ws_gp.cell(gr, 5).value
                        if v is not None and isinstance(v, (int, float)) and v != 0:
                            last_sale_row = gr
                    new_formula = f"=SUM('GROSS PROFIT'!E11:E{last_sale_row})"
                    if d != new_formula:
                        ws_npl.cell(rr, 4).value = new_formula
                        log.append(f"  REV: D{rr} formula: {d} → {new_formula}")
                    break
            break

# ─────────────────────────────────────────────────────────────────────────────
# Main entry point
# ─────────────────────────────────────────────────────────────────────────────

def post_process(output_path: str,
                 classified_accounts: list,
                 recalc: bool = True) -> dict:
    """
    Apply all post-processing fixes to an already-injected BS xlsx.

    Parameters
    ----------
    output_path          : path of the xlsx file produced by process_tb_to_bs()
    classified_accounts  : the list of dicts from result['classified_accounts']
    recalc               : if True, run LibreOffice recalc after fixing

    Returns
    -------
    dict with keys: status, fixes_applied (list of log lines), errors (list)
    """
    log    = ["=== POST-PROCESSOR START ==="]
    errors = []

    try:
        wb = load_workbook(output_path)
    except Exception as e:
        return {"status": "error", "errors": [str(e)], "fixes_applied": []}

    ws_n   = wb['notes to bs']     if 'notes to bs'     in wb.sheetnames else None
    ws_npl = wb['notes to p&l']    if 'notes to p&l'    in wb.sheetnames else None
    ws_gp  = wb['GROSS PROFIT']    if 'GROSS PROFIT'    in wb.sheetnames else None
    ws_bs  = wb['bs']              if 'bs'              in wb.sheetnames else None

    tb = classified_accounts  # shorthand

    # Run fixes
    if ws_n:
        fix_ocl(ws_n, log)
        cash_total_row = fix_cash_bank(ws_n, tb, log)
        ws_det = wb["Details"] if "Details" in wb.sheetnames else None
        fix_trade_receivables(ws_n, ws_det, log)
        stla_total_row = fix_stla(ws_n, tb, log)
        fix_st_provisions(ws_n, log)
        fix_lt_borrowings(ws_n, tb, log)

    if ws_npl:
        fix_finance_cost(ws_npl, log)
        fix_revenue_formula(ws_npl, ws_gp if ws_gp else None, log)

    if ws_gp:
        fix_gross_profit(ws_gp, tb, log)

    if ws_bs and ws_n:
        ocl_total_row  = _find_row_by_label(ws_n, ["total other current"], 55, 100)
        fix_bs_pointers(ws_bs, ws_n, ocl_total_row,
                        cash_total_row if ws_n else None,
                        stla_total_row if ws_n else None, log)
        fix_lt_bs_pointer(ws_bs, ws_n, log)

    wb.save(output_path)
    log.append("\n=== POST-PROCESSOR COMPLETE — file saved ===")

    # Optional recalc via LibreOffice
    if recalc:
        try:
            import subprocess, sys
            sys.path.insert(0, '/home/claude')
            r = subprocess.run(
                ['python3', '/home/claude/scripts/recalc.py', output_path, '90'],
                capture_output=True, text=True, timeout=120
            )
            import json
            recalc_result = json.loads(r.stdout) if r.stdout.strip() else {}
            log.append(f"\nRecalc: {recalc_result.get('status','?')}  "
                       f"errors={recalc_result.get('total_errors',0)}")
            if recalc_result.get('total_errors', 0) > 0:
                errors.append(f"Formula errors after recalc: {recalc_result['error_summary']}")
        except Exception as e:
            log.append(f"\nRecalc skipped: {e}")

    return {
        "status":       "success" if not errors else "partial",
        "fixes_applied": log,
        "errors":        errors,
    }


