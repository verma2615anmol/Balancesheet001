"""
bs_inject_config.py
===================
Config-driven injection engine.  Uses template_configs.py exact row maps —
no fuzzy matching, no row scanning, no insert_rows.

Usage
-----
    from bs_inject_config import inject_with_config
    result = inject_with_config(
        tb_path   = "trial.xlsx",         # or PDF
        template  = "template.xlsx",
        output    = "output.xlsx",
        overrides = {}                    # optional per-run overrides
    )
"""

