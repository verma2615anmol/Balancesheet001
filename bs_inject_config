def _w(ws, row: int, col: int, value, log: list, label: str = ""):
    """Write a plain value (never overwrites formula cells)."""
    cell = ws.cell(row, col)
    existing = cell.value
    if isinstance(existing, str) and existing.strip().startswith("="):
        log.append(f"  SKIP {ws.title}!R{row}C{col} (formula) [{label}]")
        return False
    cell.value = value
    log.append(f"  WRITE {ws.title}!R{row}C{col} = {value!r}  [{label}]")
    return True


def _wf(ws, row: int, col: int, formula: str, log: list, label: str = ""):
    """Write or overwrite a formula (replaces stale/wrong formulas)."""
    ws.cell(row, col).value = formula
    log.append(f"  FORMULA {ws.title}!R{row}C{col} = {formula}  [{label}]")


def _num(v) -> float:
    """Return float or 0."""
    return float(v) if isinstance(v, (int, float)) else 0.0


